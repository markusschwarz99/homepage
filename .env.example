# ==================== Postgres ====================
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=your_db_name

# Connection-URL für SQLAlchemy
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
# 'db' ist der Hostname des Postgres-Containers aus docker-compose.yml
DATABASE_URL=postgresql://your_db_user:your_secure_db_password@db:5432/your_db_name

# ==================== JWT ====================
# Generieren mit: openssl rand -hex 48
JWT_SECRET=generate_a_long_random_secret_with_openssl_rand_hex_48

# ==================== Resend (Mailversand) ====================
# API-Key erstellen unter https://resend.com/api-keys
# Permission: "Sending access" (restricted)
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# ==================== Frontend ====================
# URL über die das Frontend erreichbar ist (für Email-Links)
FRONTEND_URL=https://yourdomain.com
